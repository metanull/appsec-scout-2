{
  "version": "2.1.0",
  "$schema": "https://raw.githubusercontent.com/oasis-tcs/sarif-spec/main/sarif-2.1/schema/sarif-schema-2.1.0.json",
  "runs": [
    {
      "tool": {
        "driver": {
          "fullName": "Trivy Secret Scanner",
          "name": "Trivy",
          "rules": [
            {
              "id": "github-pat",
              "shortDescription": { "text": "GitHub Personal Access Token" },
              "fullDescription": { "text": "$githubToken = \"****************************************AB\";" },
              "helpUri": "https://github.com/aquasecurity/trivy/blob/main/pkg/fanal/secret/builtin-rules.go",
              "properties": { "tags": ["secret", "security", "CRITICAL"] }
            }
          ]
        }
      },
      "originalUriBaseIds": { "ROOTPATH": { "uri": "file:///scan/" } },
      "results": [
        {
          "ruleId": "github-pat",
          "ruleIndex": 0,
          "level": "error",
          "message": {
            "text": "Artifact: config.php\nType: \nSecret GitHub Personal Access Token\nSeverity: CRITICAL\nMatch: $githubToken = \"****************************************AB\";"
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": { "uri": "config.php", "uriBaseId": "ROOTPATH" },
                "region": { "startLine": 3, "startColumn": 1, "endLine": 3, "endColumn": 1 }
              },
              "message": { "text": "config.php" }
            }
          ]
        }
      ]
    }
  ]
}
