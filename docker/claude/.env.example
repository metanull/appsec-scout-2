# =============================================================================
# Claude Code container — environment configuration
# =============================================================================
# Copy this file to docker/claude/.env and fill in your values.
# Loaded by invoke-claude.ps1 via --env-file, layered on top of the repo root .env
# (which supplies HTTP_PROXY/HTTPS_PROXY/NO_PROXY/SSL_CERT_FILE — set those once
# there, not here). This file does NOT affect the app, mysql, or redis containers.
#
# GITHUB_TOKEN below is a last-resort fallback: invoke-claude.ps1 first tries to reuse
# the GitHub PAT already configured in appsec-scout's own credential vault (Settings >
# Integrations), so you normally don't need to set it here at all.
# =============================================================================

# ---------------------------------------------------------------------------
# Repository
# ---------------------------------------------------------------------------
# Repository to clone before starting the Claude session.
# Override per-run: invoke-claude.ps1 -Repo https://github.com/org/repo.git
REPO_URL=

# Branch to clone and use as the PR base.
# Override per-run: invoke-claude.ps1 -Branch <branch>
REPO_BRANCH=main

# ---------------------------------------------------------------------------
# Git identity
# ---------------------------------------------------------------------------
# Git display name for commits authored by Claude.
# Override per-run: invoke-claude.ps1 -Name "Your Name"
GIT_USER_NAME=

# GIT_USER_EMAIL and GITHUB_TOKEN are intentionally left last.
# Prefer supplying them at runtime to avoid storing secrets on disk:
#
#   invoke-claude.ps1 -Credential (Get-Credential)
#     UserName = your git email  →  GIT_USER_EMAIL  (commit identity)
#     Password = your GitHub PAT →  GITHUB_TOKEN    (push + gh pr create)
#
# Only set them here on machines where plaintext secrets on disk are acceptable.
GIT_USER_EMAIL=
GITHUB_TOKEN=
