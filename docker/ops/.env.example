# =============================================================================
# Ops container — environment configuration
# =============================================================================
# Copy this file to docker/ops/.env and fill in your values.
# Loaded exclusively by invoke-ops.ps1 via --env-file; it does NOT affect
# the app, mysql, or redis containers.
# =============================================================================

# ---------------------------------------------------------------------------
# Corporate proxy and custom TLS (leave empty for direct internet access)
# These are forwarded to the ops container at build time and at runtime.
# SSL_CERT_FILE: populated automatically from the Windows cert store by
#   .\scripts\invoke-ops.ps1 -Rebuild
# ---------------------------------------------------------------------------
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=
SSL_CERT_FILE=

# ---------------------------------------------------------------------------
# Repository
# ---------------------------------------------------------------------------
# Repository to clone before opening the ops shell.
# Override per-run: invoke-ops.ps1 -Repo https://github.com/org/repo.git
REPO_URL=

# Branch to clone.
# Override per-run: invoke-ops.ps1 -Branch <branch>
REPO_BRANCH=main

# ---------------------------------------------------------------------------
# Git identity
# ---------------------------------------------------------------------------
# Git display name for any commits made in the ops shell.
# Override per-run: invoke-ops.ps1 -Name "Your Name"
GIT_USER_NAME=

# GIT_USER_EMAIL and GITHUB_TOKEN are intentionally left last.
# Prefer supplying them at runtime to avoid storing secrets on disk:
#
#   invoke-ops.ps1 -Credential (Get-Credential)
#     UserName = your git email  →  GIT_USER_EMAIL  (commit identity)
#     Password = your GitHub PAT →  GITHUB_TOKEN    (clone private repos)
#
# Only set them here on machines where plaintext secrets on disk are acceptable.
GIT_USER_EMAIL=
GITHUB_TOKEN=
