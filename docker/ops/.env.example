# =============================================================================
# Ops container — environment configuration
# =============================================================================
# Copy this file to docker/ops/.env and fill in your values.
# Loaded by invoke-ops.ps1 via --env-file, layered on top of the repo root .env
# (which supplies HTTP_PROXY/HTTPS_PROXY/NO_PROXY/SSL_CERT_FILE — set those once
# there, not here). This file does NOT affect the app, mysql, or redis containers.
#
# AZDO_PAT and GITHUB_TOKEN below are last-resort fallbacks: invoke-ops.ps1 first
# tries to reuse the AzDO/GitHub PATs already configured in appsec-scout's own
# credential vault (Settings > Integrations), so you normally don't need to set
# them here at all — only the AzDO organization/repo filters and git identity are
# genuinely ops-specific.
# =============================================================================

# ---------------------------------------------------------------------------
# Repository
# ---------------------------------------------------------------------------
# Repository to clone before opening the ops shell.
# Override per-run: invoke-ops.ps1 -Repo https://github.com/org/repo.git
REPO_URL=

# Branch to clone.
# Override per-run: invoke-ops.ps1 -Branch <branch>
REPO_BRANCH=main

# ---------------------------------------------------------------------------
# Git identity
# ---------------------------------------------------------------------------
# Git display name for any commits made in the ops shell.
# Override per-run: invoke-ops.ps1 -Name "Your Name"
GIT_USER_NAME=

# GIT_USER_EMAIL and GITHUB_TOKEN are intentionally left last.
# GITHUB_TOKEN is only used if the GitHub tracker's PAT isn't configured in appsec-scout's
# credential vault (see the note at the top of this file). Prefer supplying either at
# runtime to avoid storing secrets on disk:
#
#   invoke-ops.ps1 -Credential (Get-Credential)
#     UserName = your git email  →  GIT_USER_EMAIL  (commit identity)
#     Password = your GitHub PAT →  GITHUB_TOKEN    (clone private repos)
#
# Only set them here on machines where plaintext secrets on disk are acceptable.
GIT_USER_EMAIL=
GITHUB_TOKEN=

# ---------------------------------------------------------------------------
# SBOM scan (invoke-ops.ps1 -SbomScan)
# ---------------------------------------------------------------------------
# Azure DevOps organization to scan — only used as a fallback if the AzDO source's
# organization isn't configured in appsec-scout's credential vault.
# Override per-run: invoke-ops.ps1 -SbomScan -Organization <org>
AZDO_ORG=EESC-CoR

# Personal Access Token with "Code (Read)" scope across the organization — only used as
# a fallback if the AzDO source's PAT isn't configured in appsec-scout's credential vault.
# Prefer supplying at runtime rather than storing it here:
#   invoke-ops.ps1 -SbomScan -Credential (Get-Credential)
AZDO_PAT=

# Optional regex filters applied to project/repository names, mirroring the
# -ProjectFilter/-RepositoryFilter parameters. Leave empty to scan everything.
AZDO_PROJECT_FILTER=
AZDO_REPO_FILTER=

# Host directory that receives the SBOM output (bind-mounted to /output).
# Override per-run: invoke-ops.ps1 -SbomScan -OutputDir <path>
SBOM_OUTPUT_DIR=./output/sbom-scan
