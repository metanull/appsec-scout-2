# =============================================================================
# AppSec Scout — Docker Compose environment
# =============================================================================
# Copy this file to .env and fill in your values.
# This file is read by Docker Compose ONLY — it is NOT the Laravel app config.
# Laravel configuration lives in app-laravel/.env (see app-laravel/.env.example).
# =============================================================================

# ---------------------------------------------------------------------------
# App container port
# Host port the app is exposed on. Change if 8080 is already in use.
# ---------------------------------------------------------------------------
APP_PORT=8080

# ---------------------------------------------------------------------------
# Database credentials (MySQL container)
# DB_DATABASE / DB_USERNAME / DB_PASSWORD must exactly match the values in
# app-laravel/.env so that the app can connect to the database the mysql
# container initialised.
# DB_ROOT_PASSWORD is used only by the mysql container — not by the Laravel app.
# ---------------------------------------------------------------------------
DB_ROOT_PASSWORD=rootpassword
DB_DATABASE=appsec_scout
DB_USERNAME=appsec_scout
DB_PASSWORD=password

# ---------------------------------------------------------------------------
# Corporate proxy and custom TLS (leave empty for direct internet access)
# These are the single source of truth for every container in the stack —
# app, mysql, redis, dependencytrack, claude, and ops all read them from here.
# invoke-claude.ps1/invoke-ops.ps1 layer docker/claude/.env and docker/ops/.env
# on top of this file; do not repeat these values there.
# NO_PROXY: comma-separated hosts to bypass (e.g. localhost,127.0.0.1,mysql,redis).
# SSL_CERT_FILE: path to a custom CA bundle for TLS-intercepting proxies.
#   Populated automatically from the Windows cert store by:
#   .\scripts\appsec-scout.ps1 -Rebuild
# ---------------------------------------------------------------------------
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=
SSL_CERT_FILE=

# ---------------------------------------------------------------------------
# OWASP Dependency-Track (SBOM visualization) + bundled Trivy analyzer server
# Both start automatically with the rest of the stack — not an opt-in profile.
# The dependencytrack-bootstrap one-shot container automatically logs in as
# DTRACK_ADMIN_USERNAME/DTRACK_ADMIN_PASSWORD (performing the forced first-boot
# password change if needed), grants the Automation team the permissions needed
# for BOM uploads, stores a fresh API key in AppSec Scout's credential vault,
# and configures Dependency-Track's Trivy analyzer — no manual API key,
# permission, or token setup. The shared secret between trivy-server and
# Dependency-Track is generated once inside the stack (a trivy-token-init
# container writes it to a Docker volume both containers read) — there is
# nothing to configure for it here.
# Frontend: http://localhost:8090
# API:      http://localhost:8091 (externally) / DTRACK_INTERNAL_BASE_URL (container-to-container)
# ---------------------------------------------------------------------------
DTRACK_DB_DATABASE=dtrack
DTRACK_DB_USERNAME=dtrack
DTRACK_DB_PASSWORD=dtrack
DTRACK_API_PORT=8091
DTRACK_FRONTEND_PORT=8090
DTRACK_API_BASE_URL=http://localhost:8091
DTRACK_INTERNAL_BASE_URL=http://dependencytrack-apiserver:8080
DTRACK_ADMIN_USERNAME=admin
DTRACK_ADMIN_PASSWORD=admin
DTRACK_TEAM=Automation

# trivy-server's base URL, shared by Dependency-Track's Trivy analyzer config and by
# the ops container's org-wide scans (both use the same self-hosted vulnerability
# database instead of downloading their own). Not exposed on the host; container-to-
# container only.
TRIVY_SERVER_URL=http://trivy-server:4954

# ---------------------------------------------------------------------------
# Claude Code and ops containers additionally use their own env files, layered on
# top of this one (proxy/TLS settings above still apply to both):
#   docker/claude/.env.example  →  docker/claude/.env
#   docker/ops/.env.example     →  docker/ops/.env
# Their AzDO/GitHub PATs are also unnecessary in the common case: both scripts
# reuse the credentials already stored in appsec-scout's own credential vault
# (Settings > Integrations) via the running `app` container.
# ---------------------------------------------------------------------------
